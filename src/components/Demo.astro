---
import { vibes } from '../lib/demoData';
---

<section id="demo" class="mx-auto max-w-6xl px-4 py-24">
  <p class="text-sm uppercase tracking-wide text-ink/60">Demo placeholder — flow skeleton, styling comes in step 2</p>

  <div id="demo-select" class="mt-6">
    <p>Pick a vibe:</p>
    <div class="mt-3 flex flex-wrap gap-3">
      {vibes.map((vibe) => (
        <button
          type="button"
          data-vibe={vibe.id}
          class="rounded border border-ink/20 px-4 py-2 text-sm font-semibold hover:border-ink/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-electric"
        >
          {vibe.label}
        </button>
      ))}
    </div>
  </div>

  <div id="demo-loading" hidden class="mt-6">
    <p>Reading your drip…</p>
  </div>

  <div id="demo-reveal" hidden class="mt-6"></div>
</section>

<script>
  import { vibes, type Vibe } from '../lib/demoData';

  const selectEl = document.getElementById('demo-select');
  const loadingEl = document.getElementById('demo-loading');
  const revealEl = document.getElementById('demo-reveal');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function renderReveal(vibe: Vibe) {
    if (!revealEl) return;

    const colorSwatches = vibe.profile.colors
      .map((hex) => `
        <div style="text-align:center;">
          <div style="width:32px;height:32px;border-radius:4px;background:${hex};border:1px solid rgba(0,0,0,0.15);" aria-hidden="true"></div>
          <div style="font-size:11px;margin-top:2px;">${hex}</div>
        </div>
      `)
      .join('');

    const silhouettes = vibe.profile.silhouettes.map((s) => `<li>${s}</li>`).join('');
    const tags = vibe.profile.tags.map((t) => `<li>${t}</li>`).join('');

    const lookbookItems = vibe.lookbook
      .map(
        (item) => `
        <div style="border:1px solid rgba(0,0,0,0.15);padding:8px;">
          <img src="${item.image}" alt="${item.alt}" width="160" height="160" loading="lazy" style="width:100%;height:auto;object-fit:cover;" />
          <p style="margin-top:6px;font-size:14px;">${item.name}</p>
          <p style="font-size:14px;font-weight:600;">&euro;${item.price}</p>
        </div>
      `
      )
      .join('');

    revealEl.innerHTML = `
      <p style="font-size:11px;text-transform:uppercase;letter-spacing:0.05em;">Sample</p>
      <p style="font-size:12px;text-transform:uppercase;letter-spacing:0.05em;margin-top:4px;">One store &middot; one order</p>

      <h3 style="margin-top:16px;font-weight:700;">Your Drip Profile — ${vibe.label}</h3>
      <div style="display:flex;gap:8px;margin-top:12px;">${colorSwatches}</div>
      <ul style="margin-top:12px;">${silhouettes}</ul>
      <ul style="margin-top:8px;display:flex;gap:8px;flex-wrap:wrap;list-style:none;padding:0;">${tags}</ul>
      <p style="margin-top:12px;font-style:italic;">${vibe.profile.summary}</p>

      <h3 style="margin-top:24px;font-weight:700;">Sample lookbook</h3>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;margin-top:12px;">
        ${lookbookItems}
      </div>

      <p style="margin-top:24px;">
        This is a sample. <a href="#waitlist" style="text-decoration:underline;">Join the waitlist</a> to get YOUR Drip Profile.
      </p>
    `;
  }

  function startDemo(vibe: Vibe) {
    selectEl?.setAttribute('hidden', '');

    if (prefersReducedMotion) {
      renderReveal(vibe);
      revealEl?.removeAttribute('hidden');
      return;
    }

    loadingEl?.removeAttribute('hidden');
    window.setTimeout(() => {
      loadingEl?.setAttribute('hidden', '');
      renderReveal(vibe);
      revealEl?.removeAttribute('hidden');
    }, 2000);
  }

  document.querySelectorAll<HTMLButtonElement>('[data-vibe]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const vibe = vibes.find((v) => v.id === btn.dataset.vibe);
      if (vibe) startDemo(vibe);
    });
  });
</script>
