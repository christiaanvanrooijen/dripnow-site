---
import { vibes } from '../lib/demoData';
---

<section id="demo" class="mx-auto max-w-6xl px-4 py-24">
  <div class="text-center">
    <p class="text-sm font-semibold uppercase tracking-wide text-electric">Try the demo</p>
    <h2 class="mt-2 font-display text-3xl sm:text-4xl">Pick a vibe</h2>
    <p class="mx-auto mt-3 max-w-md text-ink/70">
      No upload needed for this preview — pick a vibe and see how a Drip Profile and lookbook come together.
    </p>
  </div>

  <div id="demo-select" class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-3">
    {vibes.map((vibe) => (
      <button
        type="button"
        data-vibe={vibe.id}
        class="rounded-2xl border border-ink/15 bg-bone p-5 text-left transition-all hover:-translate-y-1 hover:border-ink/30 hover:shadow-lg hover:shadow-ink/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-electric"
      >
        <div class="flex gap-1.5">
          {vibe.profile.colors.slice(0, 4).map((hex) => (
            <span
              style={`background:${hex}`}
              class="h-5 w-5 rounded-full border border-ink/10"
              aria-hidden="true"
            />
          ))}
        </div>
        <p class="mt-4 font-display text-xl">{vibe.label}</p>
        <p class="mt-1 text-sm text-ink/60">{vibe.profile.tags[1]}</p>
      </button>
    ))}
  </div>

  <div id="demo-loading" hidden class="mt-10 flex flex-col items-center gap-4 py-16 text-center">
    <p class="font-display text-2xl">
      Reading your <span class="chrome-text">drip</span>&hellip;
    </p>
    <div class="h-1 w-40 overflow-hidden rounded-full bg-ink/10">
      <div class="h-full w-full origin-left animate-[chrome-sweep_2s_ease-in-out] bg-gradient-to-r from-chrome-2 via-chrome-1 to-chrome-2"></div>
    </div>
  </div>

  <div id="demo-reveal" hidden class="mt-10 animate-[demo-reveal-in_0.5s_ease-out]">
    <div class="mx-auto max-w-4xl">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <span class="inline-flex items-center gap-2 rounded-full border border-ink/15 px-4 py-1.5 text-xs font-medium text-ink/70">
          <span class="h-1.5 w-1.5 rounded-full bg-signal"></span>
          One store &middot; one order
        </span>
        <span class="text-xs uppercase tracking-wide text-ink/40">Sample</span>
      </div>

      <div id="demo-profile" class="mt-6 rounded-2xl border border-ink/15 bg-bone p-6 sm:p-8"></div>

      <div id="demo-lookbook" class="mt-10"></div>

      <div class="mt-12 text-center">
        <p class="text-ink/70">
          This is a sample. Join the waitlist to get <strong class="font-semibold text-ink">your</strong> Drip Profile.
        </p>
        <a
          href="#waitlist"
          class="mt-4 inline-block rounded-full bg-electric px-8 py-3.5 text-base font-semibold text-bone transition-transform hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-electric"
        >
          Join the waitlist
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { vibes, type Vibe } from '../lib/demoData';

  const selectEl = document.getElementById('demo-select');
  const loadingEl = document.getElementById('demo-loading');
  const revealEl = document.getElementById('demo-reveal');
  const profileEl = document.getElementById('demo-profile');
  const lookbookEl = document.getElementById('demo-lookbook');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function renderReveal(vibe: Vibe) {
    if (!profileEl || !lookbookEl) return;

    const colorSwatches = vibe.profile.colors
      .map(
        (hex) => `
        <span
          style="background:${hex}"
          class="h-10 w-10 rounded-lg border border-ink/10"
          title="${hex}"
          aria-label="Colour swatch ${hex}"
        ></span>
      `
      )
      .join('');

    const silhouettes = vibe.profile.silhouettes
      .map((s) => `<li class="rounded-full border border-ink/20 px-3 py-1 text-xs text-ink/80">${s}</li>`)
      .join('');

    const tags = vibe.profile.tags
      .map((t) => `<li class="rounded-full bg-ink/5 px-3 py-1 text-xs text-ink/80">${t}</li>`)
      .join('');

    profileEl.innerHTML = `
      <h3 class="font-display text-2xl">Your Drip Profile &mdash; ${vibe.label}</h3>

      <p class="mt-6 text-xs font-semibold uppercase tracking-wide text-ink/50">Colours</p>
      <div class="mt-2 flex flex-wrap gap-2">${colorSwatches}</div>

      <p class="mt-6 text-xs font-semibold uppercase tracking-wide text-ink/50">Silhouettes</p>
      <ul class="mt-2 flex flex-wrap gap-2 list-none p-0">${silhouettes}</ul>

      <p class="mt-6 text-xs font-semibold uppercase tracking-wide text-ink/50">Style tags</p>
      <ul class="mt-2 flex flex-wrap gap-2 list-none p-0">${tags}</ul>

      <p class="mt-6 text-lg font-medium leading-relaxed text-ink">${vibe.profile.summary}</p>
    `;

    const total = vibe.lookbook.reduce((sum, item) => sum + item.price, 0);

    const lookbookItems = vibe.lookbook
      .map(
        (item) => `
        <div class="rounded-xl border border-ink/15 bg-bone p-3">
          <img
            src="${item.image}"
            alt="${item.alt}"
            width="320"
            height="320"
            loading="lazy"
            class="aspect-square w-full rounded-lg object-cover"
          />
          <p class="mt-3 text-sm text-ink/80">${item.name}</p>
          <p class="mt-1 text-sm font-semibold text-ink">&euro;${item.price}</p>
        </div>
      `
      )
      .join('');

    lookbookEl.innerHTML = `
      <div class="flex flex-wrap items-baseline justify-between gap-2">
        <h3 class="font-display text-2xl">Sample lookbook</h3>
        <p class="text-sm text-ink/60">&euro;${total} total &middot; one store, one order</p>
      </div>
      <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
        ${lookbookItems}
      </div>
    `;
  }

  function startDemo(vibe: Vibe) {
    selectEl?.setAttribute('hidden', '');

    if (prefersReducedMotion) {
      renderReveal(vibe);
      revealEl?.removeAttribute('hidden');
      return;
    }

    loadingEl?.removeAttribute('hidden');
    window.setTimeout(() => {
      loadingEl?.setAttribute('hidden', '');
      renderReveal(vibe);
      revealEl?.removeAttribute('hidden');
    }, 2000);
  }

  document.querySelectorAll<HTMLButtonElement>('[data-vibe]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const vibe = vibes.find((v) => v.id === btn.dataset.vibe);
      if (vibe) startDemo(vibe);
    });
  });
</script>
