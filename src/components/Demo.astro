---
import { vibes } from '../lib/demoData';
---

<section id="demo" class="mx-auto max-w-6xl px-4 py-24 sm:py-32">
  <div class="text-center">
    <p class="text-xs font-semibold uppercase tracking-widest text-ink/50">Try the demo</p>
    <h2 class="mt-3 font-display text-4xl sm:text-5xl">Pick a vibe</h2>
    <p class="mx-auto mt-4 max-w-md text-ink/70">
      No upload needed for this preview — pick a vibe and see how a Drip Profile and lookbook come together.
    </p>
  </div>

  <div id="demo-select" class="mt-16 grid grid-cols-1 gap-10 sm:grid-cols-3 sm:gap-8">
    {vibes.map((vibe) => (
      <button
        type="button"
        data-vibe={vibe.id}
        class="group border-b border-greige/40 pb-6 text-left transition-colors hover:border-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-ink"
      >
        <div class="flex gap-1">
          {vibe.profile.colors.map((hex) => (
            <span style={`background:${hex}`} class="h-3 w-5" aria-hidden="true" />
          ))}
        </div>
        <p class="mt-5 font-display text-2xl sm:text-3xl">{vibe.label}</p>
        <p class="mt-1 text-xs uppercase tracking-widest text-ink/50">{vibe.profile.tags[1]}</p>
      </button>
    ))}
  </div>

  <div id="demo-loading" hidden class="mt-16 flex flex-col items-center gap-5 py-16 text-center">
    <p class="font-display text-3xl">
      Reading your <span class="chrome-text">drip</span>&hellip;
    </p>
    <div class="h-px w-48 overflow-hidden bg-greige/25">
      <div class="h-full w-full origin-left animate-[chrome-sweep_2s_ease-in-out] bg-gradient-to-r from-chrome-2 via-chrome-1 to-chrome-2"></div>
    </div>
  </div>

  <div id="demo-reveal" hidden class="mt-16 animate-[demo-reveal-in_0.6s_ease-out]">
    <div class="mx-auto max-w-4xl">
      <div class="flex flex-wrap items-center justify-between gap-3 text-xs uppercase tracking-widest text-ink/50">
        <span>One store &middot; one order</span>
        <span>Sample</span>
      </div>

      <div id="demo-profile" class="mt-10"></div>

      <div id="demo-lookbook" class="mt-20"></div>

      <div class="mt-20 border-t border-greige/40 pt-10 text-center">
        <p class="text-ink/70">
          This is a sample. Join the waitlist to get <strong class="font-semibold text-ink">your</strong> Drip Profile.
        </p>
        <a
          href="#waitlist"
          class="mt-6 inline-block rounded-full bg-ink px-8 py-3.5 text-base font-semibold text-bone transition-transform hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
        >
          Join the waitlist
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { vibes, type Vibe } from '../lib/demoData';

  const selectEl = document.getElementById('demo-select');
  const loadingEl = document.getElementById('demo-loading');
  const revealEl = document.getElementById('demo-reveal');
  const profileEl = document.getElementById('demo-profile');
  const lookbookEl = document.getElementById('demo-lookbook');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function renderReveal(vibe: Vibe) {
    if (!profileEl || !lookbookEl) return;

    const colorBand = vibe.profile.colors
      .map((hex) => `<span style="background:${hex}" class="h-full flex-1"></span>`)
      .join('');

    profileEl.innerHTML = `
      <h3 class="font-display text-4xl sm:text-5xl">${vibe.label}</h3>
      <div class="mt-6 border-t border-greige/40"></div>

      <div class="mt-8 flex h-10 w-full sm:h-12" role="img" aria-label="Colour palette for ${vibe.label}: ${vibe.profile.colors.join(', ')}">
        ${colorBand}
      </div>

      <p class="mt-10 text-xs uppercase tracking-widest text-ink/40">Silhouettes</p>
      <p class="mt-1 text-sm uppercase tracking-wide text-ink/70">${vibe.profile.silhouettes.join(' &middot; ')}</p>

      <p class="mt-6 text-xs uppercase tracking-widest text-ink/40">Style</p>
      <p class="mt-1 text-sm uppercase tracking-wide text-ink/70">${vibe.profile.tags.join(' &middot; ')}</p>

      <p class="mt-10 max-w-2xl text-xl font-medium leading-snug text-ink sm:text-2xl">${vibe.profile.summary}</p>
    `;

    const [hero, ...rest] = vibe.lookbook;
    const total = vibe.lookbook.reduce((sum, item) => sum + item.price, 0);

    const restItems = rest
      .map(
        (item) => `
        <div>
          <img
            src="${item.image}"
            alt="${item.alt}"
            width="160"
            height="160"
            loading="lazy"
            class="aspect-square w-full object-cover"
          />
          <div class="mt-2 flex items-baseline justify-between gap-2 border-t border-greige/30 pt-2">
            <p class="text-xs text-ink/70">${item.name}</p>
            <p class="text-xs font-semibold text-ink">&euro;${item.price}</p>
          </div>
        </div>
      `
      )
      .join('');

    lookbookEl.innerHTML = `
      <p class="text-xs uppercase tracking-widest text-ink/40">Sample lookbook</p>
      <div class="mt-8 flex flex-col gap-10 sm:flex-row sm:items-start sm:gap-12">
        <div class="sm:max-w-sm sm:flex-1">
          <img
            src="${hero.image}"
            alt="${hero.alt}"
            width="400"
            height="400"
            loading="lazy"
            class="aspect-square w-full object-cover"
          />
          <div class="mt-3 flex items-baseline justify-between gap-2 border-t border-greige/30 pt-3">
            <p class="text-sm text-ink/80">${hero.name}</p>
            <p class="text-sm font-semibold text-ink">&euro;${hero.price}</p>
          </div>
        </div>
        <div class="grid flex-1 grid-cols-2 gap-6 sm:grid-cols-3">
          ${restItems}
        </div>
      </div>
      <div class="mt-12 border-t border-greige/40 pt-4 text-sm text-ink/70">
        &euro;${total} total &middot; one store, one order
      </div>
    `;
  }

  function startDemo(vibe: Vibe) {
    selectEl?.setAttribute('hidden', '');

    if (prefersReducedMotion) {
      renderReveal(vibe);
      revealEl?.removeAttribute('hidden');
      return;
    }

    loadingEl?.removeAttribute('hidden');
    window.setTimeout(() => {
      loadingEl?.setAttribute('hidden', '');
      renderReveal(vibe);
      revealEl?.removeAttribute('hidden');
    }, 2000);
  }

  document.querySelectorAll<HTMLButtonElement>('[data-vibe]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const vibe = vibes.find((v) => v.id === btn.dataset.vibe);
      if (vibe) startDemo(vibe);
    });
  });
</script>
