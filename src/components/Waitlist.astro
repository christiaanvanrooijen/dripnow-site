---
// Tally is EU-hosted (Belgium) and its own cookie policy states it only
// uses essential/functional cookies, no analytics or ad tracking — see
// https://tally.so/help/cookie-policy. Iframes also don't share cookies
// with the parent page. That's why this embed loads unconditionally and
// is NOT gated behind the cookie-consent "accepted" state.
const TALLY_FORM_ID = 'ja22YJ';
const embedSrc = `https://tally.so/embed/${TALLY_FORM_ID}?hideTitle=1&transparentBackground=1&dynamicHeight=1`;
---

<section id="waitlist" class="mx-auto max-w-xl px-4 py-24 text-center sm:py-32">
  <h2 class="font-display text-4xl sm:text-5xl">Be first in line.</h2>
  <p class="mt-4 text-ink/70">First 500 get early access.</p>

  <div class="mx-auto mt-10 max-w-md">
    <iframe
      data-tally-src={embedSrc}
      loading="lazy"
      width="100%"
      height="200"
      title="Join the DripNow waitlist"
      class="w-full"
    ></iframe>
  </div>

  <p class="mt-6 text-xs text-ink/50">
    <a href="/privacy" class="underline hover:text-ink">Privacy</a> — We only email you about your invite. No spam.
  </p>
</section>

<script is:inline src="https://tally.so/widgets/embed.js"></script>
